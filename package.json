{
  "name": "@rootstockcollective/collective-sdk",
  "version": "0.4.0",
  "publishConfig": {
    "registry": "https://registry.npmjs.org"
  },
  "description": "Rootstock Collective DAO SDK - Interact with the Collective DAO protocol",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/RootstockCollective/collective-sdk.git"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "rootstock",
    "rsk",
    "collective",
    "dao",
    "governance",
    "staking",
    "backing"
  ],
  "author": "Sebastian Guaqueta",
  "license": "MIT",
  "dependencies": {
    "@rsksmart/w3layer": "^0.2.1",
    "@rsksmart/sdk-base": "^0.2.1",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
